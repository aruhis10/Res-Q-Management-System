-- SAFE QUEUE ENGINE: Pulls waiting users without triggering 1442
CREATE PROCEDURE sp_AssignPendingRequestToWorker(IN p_WorkerID INT)
BEGIN
    DECLARE v_PendingRequestID INT DEFAULT NULL;
    DECLARE v_HubID INT;
    DECLARE v_Speciality VARCHAR(50);
    DECLARE v_Avail VARCHAR(20);

    SELECT HubID, Pro_Speciality, AvailabilityStatus INTO v_HubID, v_Speciality, v_Avail 
    FROM WORKER WHERE WorkerID = p_WorkerID FOR UPDATE;

    IF v_Avail = 'Standby' THEN
        
        -- Safely fetch and lock the next ticket in the queue
        SELECT r.RequestID INTO v_PendingRequestID
        FROM EMERGENCY_REQUEST r
        JOIN USER u ON r.UserID = u.UserID
        JOIN MICRO_HUB mh ON u.Polygon_ID = mh.Polygon_ID
        WHERE r.Status = 'Pending' 
          AND r.Category = v_Speciality 
          AND mh.HubID = v_HubID
        ORDER BY r.RequestID ASC
        LIMIT 1
        FOR UPDATE;

        IF v_PendingRequestID IS NOT NULL THEN
            INSERT INTO DISPATCH_ASSIGNMENT (RequestID, WorkerID, Status)
            VALUES (v_PendingRequestID, p_WorkerID, 'Assigned');
            
            UPDATE EMERGENCY_REQUEST SET Status = 'Assigned' WHERE RequestID = v_PendingRequestID;
            UPDATE WORKER SET AvailabilityStatus = 'Busy' WHERE WorkerID = p_WorkerID;
        END IF;
    END IF;
END //

CREATE PROCEDURE sp_UpdateWorkerStatus(IN p_WorkerID INT, IN p_Status VARCHAR(20))
BEGIN
    DECLARE v_CurrentStatus VARCHAR(20);
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;
    
    START TRANSACTION;
        SELECT AvailabilityStatus INTO v_CurrentStatus FROM WORKER WHERE WorkerID = p_WorkerID FOR UPDATE;
        
        IF v_CurrentStatus = 'Busy' AND p_Status = 'Off-Shift' THEN
            ROLLBACK;
            SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Operations Guard: Technician cannot clock out while actively on a job.';
        END IF;

        UPDATE WORKER SET AvailabilityStatus = p_Status WHERE WorkerID = p_WorkerID;
        
        IF p_Status = 'Standby' THEN
            CALL sp_AssignPendingRequestToWorker(p_WorkerID);
        END IF;
    COMMIT;
END //

CREATE PROCEDURE sp_UpdateDispatchStatus(IN p_RequestID INT, IN p_Status VARCHAR(20))
BEGIN
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;
    
    START TRANSACTION;
        IF p_Status = 'Arrived' THEN
            UPDATE DISPATCH_ASSIGNMENT SET Status = p_Status, ArrivedTime = CURRENT_TIMESTAMP WHERE RequestID = p_RequestID;
        ELSE
            UPDATE DISPATCH_ASSIGNMENT SET Status = p_Status WHERE RequestID = p_RequestID;
        END IF;

        IF p_Status = 'EnRoute' THEN
            UPDATE EMERGENCY_REQUEST SET Status = 'EnRoute' WHERE RequestID = p_RequestID;
        END IF;
    COMMIT;
END //

-- SAFE PAYMENT PROCESSOR: Closes ticket instantly on success
CREATE PROCEDURE sp_ProcessPayment(IN p_RequestID INT, IN p_Amount DECIMAL(10,2))
BEGIN
    DECLARE v_Rows INT;
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;

    START TRANSACTION;
        UPDATE PAYMENT SET TransactionStatus = 'Success' WHERE RequestID = p_RequestID AND Amount = p_Amount AND TransactionStatus = 'Pending';
        SELECT ROW_COUNT() INTO v_Rows;

        IF v_Rows > 0 THEN
            UPDATE EMERGENCY_REQUEST SET Status = 'Completed' WHERE RequestID = p_RequestID;
            COMMIT;
        ELSE
            ROLLBACK;
            SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Payment Error: Amount mismatch or invalid request.';
        END IF;
END //

CREATE PROCEDURE sp_GenerateBill(
    IN p_RequestID INT
)
BEGIN
    DECLARE v_LaborCost DECIMAL(10,2);
    DECLARE v_PartsTotal DECIMAL(10,2);
    DECLARE v_GrandTotal DECIMAL(10,2);
    DECLARE v_IsRework BOOLEAN DEFAULT FALSE;
    DECLARE v_ArrivedTime DATETIME;
    DECLARE v_HoursWorked DECIMAL(10,4);
    DECLARE v_WorkerID INT;
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;

    SELECT IsWarrantyRework INTO v_IsRework FROM EMERGENCY_REQUEST WHERE RequestID = p_RequestID;
    SELECT ArrivedTime INTO v_ArrivedTime FROM DISPATCH_ASSIGNMENT WHERE RequestID = p_RequestID;

    IF v_ArrivedTime IS NULL THEN
        SET v_HoursWorked = 1.0;
    ELSE
        SET v_HoursWorked = TIMESTAMPDIFF(MINUTE, v_ArrivedTime, CURRENT_TIMESTAMP) / 60.0;
        IF v_HoursWorked < 0.5 THEN SET v_HoursWorked = 0.5; END IF;
    END IF;

    IF v_IsRework = TRUE THEN
        SET v_GrandTotal = 0.00;
    ELSE
        SET v_LaborCost = v_HoursWorked * 200.00;
        SELECT COALESCE(SUM(Subtotal), 0) INTO v_PartsTotal FROM REQUEST_PARTS WHERE RequestID = p_RequestID;
        SET v_GrandTotal = v_LaborCost + v_PartsTotal;
    END IF;

    START TRANSACTION;
        IF EXISTS (SELECT 1 FROM PAYMENT WHERE RequestID = p_RequestID) THEN
            UPDATE PAYMENT SET Amount = v_GrandTotal, TransactionStatus = 'Pending' WHERE RequestID = p_RequestID;
        ELSE
            INSERT INTO PAYMENT (RequestID, Amount, TransactionStatus) 
            VALUES (p_RequestID, v_GrandTotal, 'Pending');
        END IF;

        -- 1. Mark physical repair as finished
        UPDATE DISPATCH_ASSIGNMENT SET Status = 'JobDone' WHERE RequestID = p_RequestID;

        -- 2. Free technician instantly so they don't wait for customer payment
        SELECT WorkerID INTO v_WorkerID FROM DISPATCH_ASSIGNMENT WHERE RequestID = p_RequestID LIMIT 1;
        IF v_WorkerID IS NOT NULL THEN
            UPDATE WORKER SET AvailabilityStatus = 'Standby' WHERE WorkerID = v_WorkerID;
            CALL sp_AssignPendingRequestToWorker(v_WorkerID);
        END IF;

        -- 3. Auto-clear warranty reworks
        IF v_GrandTotal = 0.00 THEN
            UPDATE PAYMENT SET TransactionStatus = 'Success' WHERE RequestID = p_RequestID;
            UPDATE EMERGENCY_REQUEST SET Status = 'Completed' WHERE RequestID = p_RequestID;
        END IF;
    COMMIT;
END //

CREATE PROCEDURE sp_AddWorker(
    IN p_Name VARCHAR(100),
    IN p_Contact VARCHAR(15),
    IN p_Salary DECIMAL(10,2),
    IN p_Speciality VARCHAR(50),
    IN p_HubID INT,
    IN p_VehicleReg VARCHAR(20),
    IN p_VehicleModel VARCHAR(100),
    IN p_CleaningDuty BOOLEAN
)
BEGIN
    DECLARE v_WorkerID INT;
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;

    START TRANSACTION;
        INSERT INTO WORKER (Name, Contact_Number, Salary, Pro_Speciality, HubID, AvailabilityStatus, VerificationStatus)
        VALUES (p_Name, p_Contact, p_Salary, p_Speciality, p_HubID, 'Off-Shift', 'Verified');
        
        SET v_WorkerID = LAST_INSERT_ID();
        
        UPDATE WORKER SET PasswordHash = SHA2(CONCAT('worker', v_WorkerID), 256) WHERE WorkerID = v_WorkerID;

        INSERT INTO CONTRACT (WorkerID, VehicleReg, VehicleModel, CleaningDutyClause)
        VALUES (v_WorkerID, p_VehicleReg, p_VehicleModel, p_CleaningDuty);
    COMMIT;
END //

CREATE PROCEDURE sp_AutoDispatch(
    IN p_UserID INT,
    IN p_IssueType VARCHAR(255),
    IN p_Category VARCHAR(100),
    IN p_Location VARCHAR(255)
)
BEGIN
    DECLARE v_RequestID INT;
    DECLARE v_PolygonID INT;
    DECLARE v_WorkerID INT;
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;

    SELECT Polygon_ID INTO v_PolygonID FROM USER WHERE UserID = p_UserID;

    START TRANSACTION;
        INSERT INTO EMERGENCY_REQUEST (UserID, IssueType, Category, SpecificLocation, Status)
        VALUES (p_UserID, p_IssueType, p_Category, p_Location, 'Pending');
        SET v_RequestID = LAST_INSERT_ID();

        SELECT w.WorkerID INTO v_WorkerID
        FROM WORKER w
        JOIN MICRO_HUB mh ON w.HubID = mh.HubID
        WHERE mh.Polygon_ID = v_PolygonID 
          AND w.Pro_Speciality = p_Category 
          AND w.AvailabilityStatus = 'Standby'
        LIMIT 1
        FOR UPDATE;

        IF v_WorkerID IS NOT NULL THEN
            INSERT INTO DISPATCH_ASSIGNMENT (RequestID, WorkerID, Status)
            VALUES (v_RequestID, v_WorkerID, 'Assigned');
            UPDATE WORKER SET AvailabilityStatus = 'Busy' WHERE WorkerID = v_WorkerID;
            UPDATE EMERGENCY_REQUEST SET Status = 'Assigned' WHERE RequestID = v_RequestID;
        END IF;
    COMMIT;
END //

CREATE PROCEDURE sp_UsePart(
    IN p_WorkerID INT,
    IN p_RequestID INT,
    IN p_PartID INT,
    IN p_Quantity INT
)
BEGIN
    DECLARE v_HubID INT;
    DECLARE v_CurrentStock INT;
    DECLARE v_PartPrice DECIMAL(10,2);
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;

    SELECT HubID INTO v_HubID FROM WORKER WHERE WorkerID = p_WorkerID;

    START TRANSACTION;
        SELECT Quantity INTO v_CurrentStock
        FROM HUB_INVENTORY
        WHERE HubID = v_HubID AND PartID = p_PartID
        FOR UPDATE;

        IF v_CurrentStock IS NULL OR v_CurrentStock < p_Quantity THEN
            ROLLBACK;
            SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Inventory Error: Insufficient stock at your Hub.';
        ELSE
            UPDATE HUB_INVENTORY
            SET Quantity = Quantity - p_Quantity
            WHERE HubID = v_HubID AND PartID = p_PartID;

            SELECT Price INTO v_PartPrice FROM PART WHERE PartID = p_PartID;

            INSERT INTO REQUEST_PARTS (RequestID, PartID, Quantity, Subtotal)
            VALUES (p_RequestID, p_PartID, p_Quantity, (v_PartPrice * p_Quantity));
        END IF;
    COMMIT;
END //

CREATE PROCEDURE sp_CancelRequest(
    IN p_RequestID INT,
    IN p_UserID INT
)
BEGIN
    DECLARE v_WorkerID INT DEFAULT NULL;
    DECLARE v_CurrentStatus VARCHAR(20) DEFAULT NULL;
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;

    START TRANSACTION;
        SELECT Status INTO v_CurrentStatus
        FROM EMERGENCY_REQUEST
        WHERE RequestID = p_RequestID AND UserID = p_UserID
        LIMIT 1
        FOR UPDATE;

        IF v_CurrentStatus IN ('Pending', 'Assigned', 'EnRoute') THEN
            SET v_WorkerID = (SELECT WorkerID FROM DISPATCH_ASSIGNMENT WHERE RequestID = p_RequestID LIMIT 1);

            UPDATE EMERGENCY_REQUEST SET Status = 'Cancelled' WHERE RequestID = p_RequestID;

            INSERT INTO CANCELLATION_AUDIT (RequestID, UserID, CancelledBy, Reason, PenaltyStatus)
            VALUES (p_RequestID, p_UserID, 'Customer', 'Cancelled by Customer via Portal', 'None');

            IF v_WorkerID IS NOT NULL THEN
                DELETE FROM DISPATCH_ASSIGNMENT WHERE RequestID = p_RequestID;
                UPDATE WORKER SET AvailabilityStatus = 'Standby' WHERE WorkerID = v_WorkerID;
                CALL sp_AssignPendingRequestToWorker(v_WorkerID);
            END IF;
            COMMIT;
        ELSE
            ROLLBACK;
            SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Cancellation Error: Request not found, completed, or technician arrived.';
        END IF;
END //

CREATE PROCEDURE sp_WorkerCancelRequest(
    IN p_RequestID INT,
    IN p_WorkerID INT,
    IN p_Reason TEXT
)
BEGIN
    DECLARE v_CurrentStatus VARCHAR(20) DEFAULT NULL;
    DECLARE v_UserID INT;
    DECLARE v_IsRework BOOLEAN DEFAULT FALSE;
    DECLARE EXIT HANDLER FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;
    
    START TRANSACTION;
        SELECT Status INTO v_CurrentStatus 
        FROM DISPATCH_ASSIGNMENT 
        WHERE RequestID = p_RequestID AND WorkerID = p_WorkerID 
        LIMIT 1 
        FOR UPDATE;
        
        IF v_CurrentStatus IN ('Assigned', 'EnRoute') THEN
            -- Check rework block
            SELECT UserID, IsWarrantyRework INTO v_UserID, v_IsRework 
            FROM EMERGENCY_REQUEST 
            WHERE RequestID = p_RequestID;
            
            IF v_IsRework = TRUE THEN
                ROLLBACK;
                SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Worker Cancel Error: Cannot cancel a Warranty Rework. You must complete this job.';
            ELSE
                UPDATE EMERGENCY_REQUEST SET Status = 'Cancelled' WHERE RequestID = p_RequestID;
                
                INSERT INTO CANCELLATION_AUDIT (RequestID, UserID, CancelledBy, WorkerID, Reason, PenaltyStatus) 
                VALUES (p_RequestID, v_UserID, 'Worker', p_WorkerID, p_Reason, 'Applied');
                
                DELETE FROM DISPATCH_ASSIGNMENT WHERE RequestID = p_RequestID;
                
                UPDATE WORKER SET AvailabilityStatus = 'Standby' WHERE WorkerID = p_WorkerID;
                CALL sp_AssignPendingRequestToWorker(p_WorkerID);
                COMMIT;
            END IF;
        ELSE
            ROLLBACK;
            SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Worker Cancel Error: Cannot cancel this job right now.';
        END IF;
END //

CREATE PROCEDURE sp_RequestRestock(
    IN p_WorkerID INT,
    IN p_PartID INT
)
BEGIN
    DECLARE v_HubID INT;
    SELECT HubID INTO v_HubID FROM WORKER WHERE WorkerID = p_WorkerID;
    INSERT INTO RESTOCK_REQUEST (HubID, PartID, Status) VALUES (v_HubID, p_PartID, 'Pending');
END //

CREATE PROCEDURE sp_FulfillRestock(
    IN p_RestockRequestID INT,
    IN p_AddedQuantity INT
)
BEGIN
    DECLARE v_HubID INT;
    DECLARE v_PartID INT;
    DECLARE v_Status VARCHAR(20);
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;

    START TRANSACTION;
        SELECT HubID, PartID, Status INTO v_HubID, v_PartID, v_Status
        FROM RESTOCK_REQUEST WHERE RequestID = p_RestockRequestID FOR UPDATE;

        IF v_Status = 'Pending' THEN
            UPDATE HUB_INVENTORY SET Quantity = Quantity + p_AddedQuantity WHERE HubID = v_HubID AND PartID = v_PartID;
            UPDATE RESTOCK_REQUEST SET Status = 'Fulfilled' WHERE RequestID = p_RestockRequestID;
            COMMIT;
        ELSE
            ROLLBACK;
        END IF;
END //

CREATE PROCEDURE sp_ResolveComplaint(
    IN p_ComplaintID INT,
    IN p_ResolutionStatus VARCHAR(20)
)
BEGIN
    DECLARE v_RequestID INT;
    DECLARE v_Role VARCHAR(20);
    SELECT RequestID, Role INTO v_RequestID, v_Role FROM COMPLAINT WHERE ComplaintID = p_ComplaintID;
    UPDATE COMPLAINT SET Status = p_ResolutionStatus WHERE ComplaintID = p_ComplaintID;
    IF p_ResolutionStatus = 'Approved' AND v_Role = 'Worker' THEN
        UPDATE CANCELLATION_AUDIT SET PenaltyStatus = 'Revoked' 
        WHERE RequestID = v_RequestID AND CancelledBy = 'Worker';
    END IF;
END //

CREATE PROCEDURE sp_ApproveAndDispatchRework(
    IN p_ComplaintID INT
)
BEGIN
    DECLARE v_RequestID INT;
    DECLARE v_UserID INT;
    DECLARE v_Category VARCHAR(100);
    DECLARE v_PolygonID INT;
    DECLARE v_WorkerID INT DEFAULT NULL;
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;

    START TRANSACTION;
        SELECT RequestID INTO v_RequestID FROM COMPLAINT WHERE ComplaintID = p_ComplaintID FOR UPDATE;
        UPDATE COMPLAINT SET Status = 'Approved' WHERE ComplaintID = p_ComplaintID;

        DELETE FROM DISPATCH_ASSIGNMENT WHERE RequestID = v_RequestID;
        DELETE FROM PAYMENT WHERE RequestID = v_RequestID;

        UPDATE EMERGENCY_REQUEST SET Status = 'Pending', IsWarrantyRework = TRUE WHERE RequestID = v_RequestID;

        SELECT UserID, Category INTO v_UserID, v_Category FROM EMERGENCY_REQUEST WHERE RequestID = v_RequestID;
        SELECT Polygon_ID INTO v_PolygonID FROM USER WHERE UserID = v_UserID;

        SELECT w.WorkerID INTO v_WorkerID FROM WORKER w JOIN MICRO_HUB mh ON w.HubID = mh.HubID
        WHERE mh.Polygon_ID = v_PolygonID AND w.Pro_Speciality = v_Category AND w.AvailabilityStatus = 'Standby' LIMIT 1 FOR UPDATE;

        IF v_WorkerID IS NOT NULL THEN
            INSERT INTO DISPATCH_ASSIGNMENT (RequestID, WorkerID, Status) VALUES (v_RequestID, v_WorkerID, 'Assigned');
            UPDATE WORKER SET AvailabilityStatus = 'Busy' WHERE WorkerID = v_WorkerID;
            UPDATE EMERGENCY_REQUEST SET Status = 'Assigned' WHERE RequestID = v_RequestID;
        END IF;
    COMMIT;
END //

