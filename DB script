-- PART 2: VIEWS & SAFE TRIGGERS (CRASH-PROOFED)
-- =====================================================

CREATE VIEW vw_WorkerMonthlyPay AS
SELECT 
    w.WorkerID,
    w.Name,
    w.Salary AS BaseSalary,
    COALESCE(p.PenaltyCount, 0) AS TotalPenalties,
    (COALESCE(p.PenaltyCount, 0) * 100) AS PenaltyAmount,
    GREATEST(0, (w.Salary - (COALESCE(p.PenaltyCount, 0) * 100))) AS FinalMonthlyPay
FROM WORKER w
LEFT JOIN (
    SELECT WorkerID, COUNT(*) AS PenaltyCount
    FROM CANCELLATION_AUDIT
    WHERE CancelledBy = 'Worker' 
      AND PenaltyStatus = 'Applied'
      AND CancelDate >= DATE_ADD('2026-04-04', INTERVAL FLOOR(DATEDIFF(CURRENT_DATE, '2026-04-04')/30)*30 DAY)
    GROUP BY WorkerID
) p ON w.WorkerID = p.WorkerID;

DELIMITER //

CREATE TRIGGER trg_worker_before_update
BEFORE UPDATE ON WORKER
FOR EACH ROW
BEGIN
    IF NEW.AvailabilityStatus = 'Standby' AND NEW.VerificationStatus != 'Verified' THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Security Guard: Cannot put an unverified worker on Standby.';
    END IF;
    IF OLD.AvailabilityStatus = 'Busy' AND NEW.AvailabilityStatus = 'Off-Shift' THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Operations Guard: Technician cannot clock out while actively on a job.';
    END IF;
END //

CREATE TRIGGER trg_dispatch_before_insert
BEFORE INSERT ON DISPATCH_ASSIGNMENT
FOR EACH ROW
BEGIN
    DECLARE current_status VARCHAR(20);
    SELECT AvailabilityStatus INTO current_status FROM WORKER WHERE WorkerID = NEW.WorkerID;
    IF current_status != 'Standby' THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Dispatch Error: Worker is not on Standby. Cannot assign job.';
    END IF;
END //

CREATE TRIGGER trg_request_before_insert
BEFORE INSERT ON EMERGENCY_REQUEST
FOR EACH ROW
BEGIN
    DECLARE active_requests INT;
    SELECT COUNT(*) INTO active_requests FROM EMERGENCY_REQUEST WHERE UserID = NEW.UserID AND Status = 'Pending';
    IF active_requests >= 1 THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Spam Guard: You already have a repair technician on the way!';
    END IF;
END //

CREATE TRIGGER trg_user_before_delete
BEFORE DELETE ON USER
FOR EACH ROW
BEGIN
    DECLARE active_jobs INT;
    SELECT COUNT(*) INTO active_jobs FROM EMERGENCY_REQUEST WHERE UserID = OLD.UserID AND Status = 'Pending';
    IF active_jobs > 0 THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Fraud Prevention: Cannot delete account with an active emergency request.';
    END IF;
END //

DELIMITER ;

