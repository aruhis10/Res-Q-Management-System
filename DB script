DROP DATABASE IF EXISTS ResQ_DB;
CREATE DATABASE ResQ_DB;
USE ResQ_DB;

CREATE TABLE POLYGON (
    PolygonID INT AUTO_INCREMENT PRIMARY KEY,
    ZoneName VARCHAR(100) NOT NULL,
    BoundaryCoordinates VARCHAR(255) NOT NULL CHECK (LENGTH(BoundaryCoordinates) > 50)
);

CREATE TABLE USER (
    UserID INT AUTO_INCREMENT PRIMARY KEY,
    Name VARCHAR(100) NOT NULL,
    Email VARCHAR(100) UNIQUE NOT NULL CHECK (Email LIKE '%@%'),
    Phone VARCHAR(15) NOT NULL CHECK (LENGTH(Phone) >= 10),
    Address VARCHAR(255) DEFAULT NULL,
    Landmark VARCHAR(255) DEFAULT NULL,
    Zone VARCHAR(50) DEFAULT NULL,
    Latitude DECIMAL(10, 8) NOT NULL CHECK (Latitude BETWEEN -90 AND 90),
    Longitude DECIMAL(10, 8) NOT NULL CHECK (Longitude BETWEEN -180 AND 180),
    Polygon_ID INT NOT NULL,
    PasswordHash VARCHAR(255) NOT NULL DEFAULT '',
    FOREIGN KEY (Polygon_ID) REFERENCES POLYGON(PolygonID)
);

CREATE TABLE MICRO_HUB (
    HubID INT AUTO_INCREMENT PRIMARY KEY,
    LocationAddress VARCHAR(255) NOT NULL,
    Polygon_ID INT UNIQUE NOT NULL, 
    FOREIGN KEY (Polygon_ID) REFERENCES POLYGON(PolygonID)
);

CREATE TABLE HELPER (
    HelperID INT AUTO_INCREMENT PRIMARY KEY,
    Name VARCHAR(100) NOT NULL,
    Email VARCHAR(100) UNIQUE NOT NULL,
    Phone VARCHAR(15) UNIQUE NOT NULL,
    DateOfJoining DATE DEFAULT (CURRENT_DATE),
    HubID INT NOT NULL,
    PasswordHash VARCHAR(255) NOT NULL DEFAULT '',
    FOREIGN KEY (HubID) REFERENCES MICRO_HUB(HubID)
);

CREATE TABLE WORKER (
    WorkerID INT AUTO_INCREMENT PRIMARY KEY,
    Name VARCHAR(100) NOT NULL,
    Contact_Number VARCHAR(15) UNIQUE NOT NULL CHECK (LENGTH(Contact_Number) >= 10),
    Salary DECIMAL(10, 2) NOT NULL CHECK (Salary >= 0),
    VerificationStatus ENUM('Verified', 'Pending', 'Rejected') DEFAULT 'Pending' NOT NULL,
    AvailabilityStatus ENUM('Standby', 'Busy', 'Off-Shift') DEFAULT 'Off-Shift' NOT NULL,
    Pro_Speciality ENUM('Plumbing', 'Electrical') DEFAULT 'Electrical' NOT NULL,
    HubID INT NOT NULL,
    PasswordHash VARCHAR(255) NOT NULL DEFAULT '',
    FOREIGN KEY (HubID) REFERENCES MICRO_HUB(HubID)
);

CREATE TABLE CONTRACT (
    ContractID INT AUTO_INCREMENT PRIMARY KEY,
    WorkerID INT UNIQUE NOT NULL,
    VehicleReg VARCHAR(20) NOT NULL CHECK (LENGTH(VehicleReg) > 6),
    VehicleModel VARCHAR(100) NOT NULL,
    CleaningDutyClause BOOLEAN DEFAULT FALSE NOT NULL,
    FOREIGN KEY (WorkerID) REFERENCES WORKER(WorkerID) ON DELETE CASCADE
);

CREATE TABLE PART (
    PartID INT AUTO_INCREMENT PRIMARY KEY,
    Name VARCHAR(100) NOT NULL,
    Category VARCHAR(50) NOT NULL,
    Description VARCHAR(255) NOT NULL, 
    Price DECIMAL(10, 2) NOT NULL CHECK (Price >= 0)
);

CREATE TABLE HUB_INVENTORY (
    HubID INT,
    PartID INT,
    Quantity INT DEFAULT 0 CHECK (Quantity >= 0) NOT NULL,
    PRIMARY KEY (HubID, PartID),
    FOREIGN KEY (HubID) REFERENCES MICRO_HUB(HubID),
    FOREIGN KEY (PartID) REFERENCES PART(PartID)
);

CREATE TABLE EMERGENCY_REQUEST (
    RequestID INT AUTO_INCREMENT PRIMARY KEY,
    UserID INT NOT NULL,
    Timestamp DATETIME DEFAULT CURRENT_TIMESTAMP NOT NULL,
    IssueType VARCHAR(100) NOT NULL,
    Category ENUM('Plumbing', 'Electrical', 'Both') DEFAULT 'Electrical' NOT NULL,
    SpecificLocation VARCHAR(255) DEFAULT 'Same as registered address',
    Status ENUM('Pending', 'EnRoute', 'Assigned', 'Completed', 'Cancelled') DEFAULT 'Pending' NOT NULL,
    IsWarrantyRework BOOLEAN DEFAULT FALSE, 
    FOREIGN KEY (UserID) REFERENCES USER(UserID) ON DELETE CASCADE
);

CREATE TABLE DISPATCH_ASSIGNMENT (
    AssignmentID INT AUTO_INCREMENT PRIMARY KEY,
    RequestID INT UNIQUE NOT NULL,
    WorkerID INT NOT NULL,
    DispatchTime DATETIME DEFAULT CURRENT_TIMESTAMP NOT NULL,
    ArrivedTime DATETIME DEFAULT NULL,
    Status ENUM('EnRoute', 'Arrived', 'Assigned', 'JobDone') DEFAULT 'Assigned' NOT NULL,
    FOREIGN KEY (RequestID) REFERENCES EMERGENCY_REQUEST(RequestID) ON DELETE CASCADE,
    FOREIGN KEY (WorkerID) REFERENCES WORKER(WorkerID)
);

CREATE TABLE REQUEST_PARTS (
    LogID INT AUTO_INCREMENT PRIMARY KEY,
    RequestID INT NOT NULL,
    PartID INT NOT NULL,
    Quantity INT NOT NULL,
    Subtotal DECIMAL(10,2) NOT NULL,
    FOREIGN KEY (RequestID) REFERENCES EMERGENCY_REQUEST(RequestID) ON DELETE CASCADE,
    FOREIGN KEY (PartID) REFERENCES PART(PartID)
);

CREATE TABLE PAYMENT (
    PaymentID INT AUTO_INCREMENT PRIMARY KEY,
    RequestID INT UNIQUE NOT NULL,
    Amount DECIMAL(10, 2) NOT NULL CHECK (Amount >= 0 AND Amount <= 100000),
    TransactionStatus ENUM('Pending', 'Success', 'Failed') DEFAULT 'Pending' NOT NULL,
    FOREIGN KEY (RequestID) REFERENCES EMERGENCY_REQUEST(RequestID) ON DELETE CASCADE
);

CREATE TABLE CANCELLATION_AUDIT (
    LogID INT AUTO_INCREMENT PRIMARY KEY,
    RequestID INT NOT NULL,
    UserID INT NOT NULL,
    CancelledBy ENUM('Customer', 'Worker') DEFAULT 'Customer',
    WorkerID INT DEFAULT NULL,
    Reason TEXT DEFAULT NULL,
    CancelDate DATETIME DEFAULT CURRENT_TIMESTAMP,
    PenaltyStatus ENUM('Applied', 'Revoked', 'None') DEFAULT 'None'
);

CREATE TABLE RESTOCK_REQUEST (
    RequestID INT AUTO_INCREMENT PRIMARY KEY,
    HubID INT NOT NULL,
    PartID INT NOT NULL,
    QuantityRequested INT DEFAULT 50, 
    Status ENUM('Pending', 'Fulfilled') DEFAULT 'Pending',
    RequestDate DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (HubID) REFERENCES MICRO_HUB(HubID),
    FOREIGN KEY (PartID) REFERENCES PART(PartID)
);

CREATE TABLE COMPLAINT (
    ComplaintID INT AUTO_INCREMENT PRIMARY KEY,
    Role ENUM('Customer', 'Worker') NOT NULL,
    UserID_or_WorkerID INT NOT NULL, 
    RequestID INT NOT NULL,
    ComplaintText TEXT NOT NULL,
    ProofMedium ENUM('WhatsApp', 'Email', 'None') DEFAULT 'None',
    Status ENUM('Pending', 'Approved', 'Rejected') DEFAULT 'Pending',
    CreatedAt DATETIME DEFAULT CURRENT_TIMESTAMP,
    HelperID INT DEFAULT NULL, 
    FOREIGN KEY (RequestID) REFERENCES EMERGENCY_REQUEST(RequestID) ON DELETE CASCADE,
    FOREIGN KEY (HelperID) REFERENCES HELPER(HelperID) ON DELETE SET NULL 
);

CREATE TABLE ADMIN (
    AdminID INT AUTO_INCREMENT PRIMARY KEY,
    Username VARCHAR(50) UNIQUE NOT NULL,
    PasswordHash VARCHAR(255) NOT NULL
);

CREATE INDEX idx_worker_hub_status ON WORKER(HubID, AvailabilityStatus);
CREATE INDEX idx_request_timestamp ON EMERGENCY_REQUEST(Timestamp);
CREATE INDEX idx_request_status ON EMERGENCY_REQUEST(Status);
CREATE INDEX idx_part_name ON PART(Name);
CREATE INDEX idx_payment_status ON PAYMENT(TransactionStatus);
CREATE INDEX idx_dispatch_status ON DISPATCH_ASSIGNMENT(Status);

