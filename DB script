DELIMITER //

-- SAFE APPROVAL PROCEDURE
CREATE PROCEDURE sp_ApproveAndDispatchRework(
    IN p_ComplaintID INT
)
BEGIN
    DECLARE v_RequestID INT;
    DECLARE v_CurrentStatus VARCHAR(20);
    DECLARE v_UserID INT;
    DECLARE v_Category VARCHAR(100);
    DECLARE v_PolygonID INT;
    DECLARE v_WorkerID INT DEFAULT NULL;
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;

    START TRANSACTION;
        -- 1. Lock the complaint and check its current status
        SELECT RequestID, Status INTO v_RequestID, v_CurrentStatus 
        FROM COMPLAINT WHERE ComplaintID = p_ComplaintID FOR UPDATE;

        -- 2. The Shield: If someone else already clicked it, abort immediately!
        IF v_CurrentStatus != 'Pending' THEN
            ROLLBACK;
            SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Collision Prevented: Another Helper has already processed this complaint.';
        END IF;

        UPDATE COMPLAINT SET Status = 'Approved' WHERE ComplaintID = p_ComplaintID;

        DELETE FROM DISPATCH_ASSIGNMENT WHERE RequestID = v_RequestID;
        DELETE FROM PAYMENT WHERE RequestID = v_RequestID;

        UPDATE EMERGENCY_REQUEST SET Status = 'Pending', IsWarrantyRework = TRUE WHERE RequestID = v_RequestID;

        SELECT UserID, Category INTO v_UserID, v_Category FROM EMERGENCY_REQUEST WHERE RequestID = v_RequestID;
        SELECT Polygon_ID INTO v_PolygonID FROM USER WHERE UserID = v_UserID;

        SELECT w.WorkerID INTO v_WorkerID FROM WORKER w JOIN MICRO_HUB mh ON w.HubID = mh.HubID
        WHERE mh.Polygon_ID = v_PolygonID AND w.Pro_Speciality = v_Category AND w.AvailabilityStatus = 'Standby' LIMIT 1 FOR UPDATE;

        IF v_WorkerID IS NOT NULL THEN
            INSERT INTO DISPATCH_ASSIGNMENT (RequestID, WorkerID, Status) VALUES (v_RequestID, v_WorkerID, 'Assigned');
            UPDATE WORKER SET AvailabilityStatus = 'Busy' WHERE WorkerID = v_WorkerID;
            UPDATE EMERGENCY_REQUEST SET Status = 'Assigned' WHERE RequestID = v_RequestID;
        END IF;
    COMMIT;
END //

CREATE PROCEDURE sp_RejectComplaint(
    IN p_ComplaintID INT
)
BEGIN
    DECLARE v_CurrentStatus VARCHAR(20);
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;

    START TRANSACTION;
        -- 1. Lock the complaint
        SELECT Status INTO v_CurrentStatus FROM COMPLAINT WHERE ComplaintID = p_ComplaintID FOR UPDATE;

        -- 2. The Shield: Abort if already processed
        IF v_CurrentStatus != 'Pending' THEN
            ROLLBACK;
            SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Collision Prevented: Another Helper has already processed this complaint.';
        END IF;

        UPDATE COMPLAINT SET Status = 'Rejected' WHERE ComplaintID = p_ComplaintID;
    COMMIT;
END //

DELIMITER ;

