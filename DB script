DELIMITER //
CREATE PROCEDURE sp_UpdateWorkerStatus(IN p_WorkerID INT, IN p_Status VARCHAR(20))
BEGIN
    DECLARE v_CurrentStatus VARCHAR(20);
    DECLARE exit handler FOR SQLEXCEPTION BEGIN ROLLBACK; RESIGNAL; END;
    
    START TRANSACTION;
        -- Lock the row and check the current status
        SELECT AvailabilityStatus INTO v_CurrentStatus FROM WORKER WHERE WorkerID = p_WorkerID FOR UPDATE;
        
        -- THE FIX: Block ANY manual UI overrides if the worker is currently Busy
        IF v_CurrentStatus = 'Busy' THEN
            ROLLBACK;
            SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Action Denied: Cannot manually change status while actively assigned to a job.';
        END IF;

        -- If they aren't busy, allow the change
        UPDATE WORKER SET AvailabilityStatus = p_Status WHERE WorkerID = p_WorkerID;
        
        -- If they just clocked in, check if there's a line of customers waiting!
        IF p_Status = 'Standby' THEN
            CALL sp_AssignPendingRequestToWorker(p_WorkerID);
        END IF;
    COMMIT;
END //
DELIMITER ;

